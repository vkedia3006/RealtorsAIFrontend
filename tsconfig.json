{
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "lib": [ "es2015", "DOM" ],
    "module": "esnext",
    "moduleResolution": "bundler", 
  },
  "include": ["src/**/*"]
}